# Shared production values
NODE_ENV=production

# Database
POSTGRES_USER=logistics
POSTGRES_PASSWORD=change-me
POSTGRES_DB=logistics_crm
DATABASE_URL=postgresql://logistics:change-me@postgres:5432/logistics_crm

# Redis
